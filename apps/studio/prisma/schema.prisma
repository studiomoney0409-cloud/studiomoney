generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════════════════
// MULTI-TENANCY CORE
// ═══════════════════════════════════════════════════════════════════════════

model User {
  id         String      @id           // Clerk userId (e.g. "user_abc123")
  email      String      @unique
  name       String      @default("")
  imageUrl   String      @default("")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  workspaces Workspace[]

  @@map("users")
}

model Workspace {
  id           String   @id @default(cuid())
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name         String                       // "K-pop 매거진"
  slug         String                       // URL-safe identifier
  niche        String                       // "music" | "tech" | "fashion" | "lifestyle" | "custom"
  keywords     String[] @default([])        // user-defined search seeds
  trendSources Json                         // { google: true, reddit: { subs: [...] }, spotify: false }
  promptHints  String   @default("") @db.Text   // niche-specific prompt context injection
  language     String   @default("ko")
  region       String   @default("KR")
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Children (cascaded on delete)
  personas              WritingPersona[]
  snsAccounts           SnsAccount[]
  blogPosts             BlogPost[]
  pipelineRuns          PipelineRun[]
  topicDrafts           TopicDraft[]
  brandKits             BrandKit[]
  autopilotConfigs      AutopilotConfig[]
  trendSnapshots        TrendSnapshot[]
  topicPerformance      TopicPerformance[]
  publications          Publication[]
  postPerformance       PostPerformance[]
  referenceAccounts     ReferenceAccount[]
  incomingMessages      IncomingMessage[]
  autoReplyRules        AutoReplyRule[]
  keywordCampaigns      KeywordCampaign[]
  analyticsSnapshots    AnalyticsSnapshot[]
  designEntries         DesignEntry[]
  designProjects        DesignProject[]
  moodSearches          MoodSearch[]
  styleMemoryEntries    StyleMemoryEntry[]
  designQualityEntries  DesignQualityEntry[]
  stylePerformance      StylePerformanceEntry[]
  imageGenHistory       ImageGenHistory[]
  linkImports           LinkImport[]
  agentRuns             AgentRun[]
  weeklyPlans           WeeklyPlan[]
  dailyBriefings        DailyBriefing[]
  imageGates            ImageGate[]
  calendarEvents        CalendarEvent[]
  contentPlans          ContentPlan[]
  articleChunks         ArticleChunk[]
  subscribers           Subscriber[]
  newsletterIssues      NewsletterIssue[]
  sponsorDeals          SponsorDeal[]
  affiliateLinks        AffiliateLink[]
  revenueEvents         RevenueEvent[]
  partners              Partner[]
  outreachCampaigns     OutreachCampaign[]

  @@unique([ownerId, slug])
  @@index([ownerId])
  @@index([niche])
  @@map("workspaces")
}

model NicheTemplate {
  id              String   @id @default(cuid())
  niche           String   @unique          // "music" | "tech" | "fashion" | "lifestyle" | "custom"
  displayName     String                    // "음악 매거진"
  description     String   @default("") @db.Text
  defaultKeywords String[] @default([])
  defaultSources  Json                      // active trend source preset
  promptHints     String   @db.Text         // persona system prompt template
  defaultPersona  Json                      // baseline persona blueprint
  redditSubs      String[] @default([])
  categories      String[] @default([])     // ReferenceAccount category options for this niche
  iconEmoji       String   @default("📦")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("niche_templates")
}

// ═══════════════════════════════════════════════════════════════════════════
// CONTENT & DESIGN ARTIFACTS (workspace-scoped)
// ═══════════════════════════════════════════════════════════════════════════

model DesignEntry {
  id           String    @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category     String    @default("")
  title        String
  imageDataUri String    @db.Text
  html         String    @db.Text
  fontMood     String    @default("")
  createdAt    DateTime  @default(now())

  @@index([workspaceId, category])
  @@map("design_entries")
}

model CalendarEvent {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  date        String
  title       String
  type        String
  category    String    @default("")
  status      String    @default("planned")
  note        String    @default("")
  createdAt   DateTime  @default(now())

  @@index([workspaceId, date])
  @@map("calendar_events")
}

model ContentPlan {
  id          String     @id @default(uuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  startDate   String
  endDate     String
  frequency   Json
  summary     String     @default("")
  preferences Json?
  createdAt   DateTime   @default(now())
  items       PlanItem[]

  @@index([workspaceId])
  @@map("content_plans")
}

model PlanItem {
  id              String      @id @default(uuid())
  date            String
  title           String
  description     String      @default("")
  type            String
  category        String
  tags            String[]    @default([])
  reasoning       String      @default("")
  addedToCalendar Boolean     @default(false)
  calendarEventId String?

  planId String
  plan   ContentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("plan_items")
}

model MoodSearch {
  id           String    @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  imageDataUri String    @db.Text
  moodKeywords String[]  @default([])
  colorPalette String[]  @default([])
  atmosphere   String    @default("")
  resultCount  Int       @default(0)
  createdAt    DateTime  @default(now())

  @@index([workspaceId])
  @@map("mood_searches")
}

model DesignProject {
  id               String    @id @default(uuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title            String
  status           String    @default("draft")
  category         String    @default("")
  specJson         Json
  thumbnailDataUri String    @default("") @db.Text
  planItemId       String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([workspaceId, status])
  @@index([planItemId])
  @@map("design_projects")
}

// ═══════════════════════════════════════════════════════════════════════════
// GLOBAL SHARED RESOURCES (no workspace scoping)
// ═══════════════════════════════════════════════════════════════════════════

model BenchmarkReport {
  id               String   @id @default(uuid())
  title            String
  source           String   @default("")
  imageCount       Int      @default(0)
  slideComposition Json?
  writingStyle     Json?
  visualDesign     Json?
  insights         Json?
  rawAnalysis      Json?
  screenshots      Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([createdAt])
  @@map("benchmark_reports")
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ═══════════════════════════════════════════════════════════════════════════
// INFRASTRUCTURE: SNS Accounts, Jobs, Webhooks
// ═══════════════════════════════════════════════════════════════════════════

model SnsAccount {
  id              String    @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform        String    // threads | instagram | x | youtube | tiktok | linkedin | wordpress | facebook | pinterest | telegram
  platformUserId  String
  displayName     String    @default("")
  profileImageUrl String    @default("")
  accessToken     String    @db.Text
  refreshToken    String    @default("") @db.Text
  tokenExpiresAt  DateTime?
  scopes          String[]  @default([])
  isActive        Boolean   @default(true)
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([workspaceId, platform, platformUserId])
  @@index([workspaceId, platform])
  @@map("sns_accounts")
}

model Job {
  id          String    @id @default(uuid())
  type        String    // publish | autopilot_scan | comment_monitor | keyword_scan | analytics_collect
  status      String    @default("pending")
  priority    Int       @default(0)
  payload     Json
  result      Json?
  error       String?   @db.Text
  scheduledAt DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  retryCount  Int       @default(0)
  maxRetries  Int       @default(3)
  createdAt   DateTime  @default(now())

  @@index([status, scheduledAt])
  @@index([type, status])
  @@map("jobs")
}

model CronSchedule {
  id         String    @id @default(uuid())
  name       String    @unique
  cronExpr   String
  jobType    String
  jobPayload Json?
  isActive   Boolean   @default(true)
  lastRunAt  DateTime?
  nextRunAt  DateTime?
  createdAt  DateTime  @default(now())

  @@map("cron_schedules")
}

model WebhookEvent {
  id           String    @id @default(uuid())
  platform     String
  eventType    String    // comment | dm | mention | follow
  payload      Json
  processed    Boolean   @default(false)
  processedAt  DateTime?
  snsAccountId String?
  createdAt    DateTime  @default(now())

  @@index([platform, processed])
  @@index([createdAt])
  @@map("webhook_events")
}

// ═══════════════════════════════════════════════════════════════════════════
// CONTENT CREATION: Personas, Link Imports
// ═══════════════════════════════════════════════════════════════════════════

model LinkImport {
  id                 String    @id @default(uuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  urls               String[]
  commonInstructions String    @default("")
  status             String    @default("pending") // pending | processing | completed | failed
  results            Json?
  generatedPostIds   String[]  @default([])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([workspaceId, status])
  @@map("link_imports")
}

model WritingPersona {
  id               String    @id @default(uuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name             String
  creationMethod   String    // copy | analyze | manual | template
  sourceAccountId  String?

  perspective      String   @default("")
  expertiseAreas   String[] @default([])

  tone             Json?
  emotionalDrivers String[] @default([])

  vocabulary       Json?
  structure        Json?

  contentRules     Json?
  channelProfiles  Json?
  goldenExamples   Json?

  topicPrefs       Json?
  sampleTexts      Json?
  styleFingerprint String   @default("") @db.Text
  isDefault        Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("writing_personas")
}

// ═══════════════════════════════════════════════════════════════════════════
// PUBLISHING PIPELINE
// ═══════════════════════════════════════════════════════════════════════════

model Publication {
  id              String    @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectId       String?
  snsAccountId    String
  platform        String
  status          String    @default("draft") // draft | scheduled | publishing | published | failed
  scheduledAt     DateTime?
  publishedAt     DateTime?
  platformPostId  String?
  platformPostUrl String?
  content         Json
  personaId       String?
  error           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([workspaceId, status])
  @@index([scheduledAt])
  @@index([snsAccountId])
  @@index([personaId])
  @@map("publications")
}

model PostPerformance {
  id              String    @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  publicationId   String
  snsAccountId    String
  platform        String
  publishedAt     DateTime
  hourOfDay       Int
  dayOfWeek       Int
  views           Int       @default(0)
  likes           Int       @default(0)
  comments        Int       @default(0)
  shares          Int       @default(0)
  saves           Int       @default(0)
  engagementRate  Float     @default(0)
  snapshotAt      DateTime  @default(now())

  @@index([workspaceId, snsAccountId])
  @@index([publishedAt])
  @@map("post_performance")
}

// ═══════════════════════════════════════════════════════════════════════════
// AUTOPILOT
// ═══════════════════════════════════════════════════════════════════════════

model AutopilotConfig {
  id            String    @id @default(uuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  snsAccountId  String
  personaId     String?
  platforms     String[]
  postsPerDay   Int       @default(1)
  approvalMode  String    @default("manual")
  isActive      Boolean   @default(false)
  topicKeywords String[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  proposals AutopilotProposal[]

  @@index([workspaceId])
  @@index([snsAccountId])
  @@map("autopilot_configs")
}

model AutopilotProposal {
  id                String          @id @default(uuid())
  autopilotConfigId String
  config            AutopilotConfig @relation(fields: [autopilotConfigId], references: [id], onDelete: Cascade)
  topic             String
  reasoning         String          @db.Text
  content           Json
  platform          String
  status            String          @default("pending")
  scheduledAt       DateTime?
  publishedAt       DateTime?
  publicationId     String?
  personaId         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([autopilotConfigId])
  @@index([status])
  @@map("autopilot_proposals")
}

// ═══════════════════════════════════════════════════════════════════════════
// COMMENT / DM MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════

model IncomingMessage {
  id             String    @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  snsAccountId   String
  platform       String
  externalId     String
  parentPostId   String?
  senderName     String
  senderHandle   String
  messageType    String    @default("comment")
  body           String    @db.Text
  classification String?
  sentiment      String?
  priority       String    @default("normal")
  isGoldenTime   Boolean   @default(false)
  autoReplied    Boolean   @default(false)
  autoReplyText  String?   @db.Text
  isRead         Boolean   @default(false)
  receivedAt     DateTime  @default(now())
  processedAt    DateTime?

  @@unique([platform, externalId])
  @@index([workspaceId, snsAccountId, isRead])
  @@index([classification])
  @@map("incoming_messages")
}

model AutoReplyRule {
  id             String    @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  snsAccountId   String
  name           String
  isActive       Boolean   @default(true)
  triggerType    String
  triggerValue   String
  replyTemplate  String    @db.Text
  useAi          Boolean   @default(false)
  aiInstructions String?   @db.Text
  createdAt      DateTime  @default(now())

  @@index([workspaceId, snsAccountId])
  @@map("auto_reply_rules")
}

// ═══════════════════════════════════════════════════════════════════════════
// KEYWORD CAMPAIGN
// ═══════════════════════════════════════════════════════════════════════════

model KeywordCampaign {
  id              String    @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  snsAccountId    String
  name            String
  keywords        String[]
  platforms       String[]
  commentMode     String    @default("ai")
  commentTemplate String?   @db.Text
  aiInstructions  String?   @db.Text
  dailyLimit      Int       @default(10)
  todayCount      Int       @default(0)
  operatingStart  Int       @default(9)
  operatingEnd    Int       @default(22)
  minDelaySec     Int       @default(30)
  maxDelaySec     Int       @default(300)
  isActive        Boolean   @default(false)
  tosWarningAcked Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  logs KeywordCommentLog[]

  @@index([workspaceId, snsAccountId])
  @@map("keyword_campaigns")
}

model KeywordCommentLog {
  id             String          @id @default(uuid())
  campaignId     String
  campaign       KeywordCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  platform       String
  targetPostId   String?
  targetPostUrl  String
  targetPostText String?         @db.Text
  commentText    String          @db.Text
  status         String          @default("pending")
  error          String?
  postedAt       DateTime?
  createdAt      DateTime        @default(now())

  @@index([campaignId])
  @@index([status])
  @@map("keyword_comment_logs")
}

// ═══════════════════════════════════════════════════════════════════════════
// ANALYTICS & BLOG
// ═══════════════════════════════════════════════════════════════════════════

model AnalyticsSnapshot {
  id              String    @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  snsAccountId    String
  platform        String
  date            DateTime  @db.Date
  followers       Int       @default(0)
  followersGrowth Int       @default(0)
  reach           Int       @default(0)
  impressions     Int       @default(0)
  engagement      Int       @default(0)
  engagementRate  Float     @default(0)
  profileViews    Int       @default(0)
  demographics    Json?
  topPosts        Json?
  createdAt       DateTime  @default(now())

  @@unique([snsAccountId, date])
  @@index([workspaceId, snsAccountId, platform])
  @@map("analytics_snapshots")
}

model BlogPost {
  id             String    @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title          String
  slug           String
  content        String    @db.Text
  excerpt        String    @default("") @db.Text
  seoTitle       String    @default("")
  seoDescription String    @default("") @db.Text
  seoKeywords    String[]
  wordCount      Int       @default(0)
  status         String    @default("draft")
  personaId      String?
  pipelineRunId  String?   @unique
  publishedAt    DateTime?
  coverImageUrl  String?   @db.Text
  visualAssets   Json?
  publishedUrl   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  pipelineRun PipelineRun? @relation(fields: [pipelineRunId], references: [id])

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@map("blog_posts")
}

// ═══════════════════════════════════════════════════════════════════════════
// MUSIC KNOWLEDGE GRAPH (global shared catalog — no workspace scoping)
// ═══════════════════════════════════════════════════════════════════════════

model MusicArtist {
  id            String    @id @default(uuid())
  name          String
  nameKo        String    @default("")
  aliases       String[]  @default([])
  type          String    @default("person")
  spotifyId     String?   @unique
  musicBrainzId String?   @unique
  genres        String[]  @default([])
  bio           String    @default("") @db.Text
  bioKo         String    @default("") @db.Text
  imageUrl      String    @default("")
  popularity    Int       @default(0)
  followers     Int       @default(0)
  activeFrom    String?
  activeTo      String?
  country       String    @default("")
  metadata      Json?
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  albums        MusicAlbum[]
  relationsFrom ArtistRelation[] @relation("from")
  relationsTo   ArtistRelation[] @relation("to")

  @@index([spotifyId])
  @@index([name])
  @@map("music_artists")
}

model MusicAlbum {
  id              String      @id @default(uuid())
  title           String
  titleKo         String      @default("")
  artistId        String
  artist          MusicArtist @relation(fields: [artistId], references: [id])
  spotifyId       String?     @unique
  musicBrainzId   String?     @unique
  releaseDate     String?
  albumType       String      @default("album")
  totalTracks     Int         @default(0)
  label           String      @default("")
  genres          String[]    @default([])
  imageUrl        String      @default("")
  popularity      Int         @default(0)
  avgDanceability Float?
  avgEnergy       Float?
  avgValence      Float?
  avgTempo        Float?
  metadata        Json?
  lastSyncedAt    DateTime?
  createdAt       DateTime    @default(now())

  tracks MusicTrack[]

  @@index([artistId])
  @@index([releaseDate])
  @@map("music_albums")
}

model MusicTrack {
  id               String     @id @default(uuid())
  title            String
  albumId          String
  album            MusicAlbum @relation(fields: [albumId], references: [id])
  spotifyId        String?    @unique
  trackNumber      Int        @default(0)
  durationMs       Int        @default(0)
  popularity       Int        @default(0)
  previewUrl       String?
  danceability     Float?
  energy           Float?
  valence          Float?
  tempo            Float?
  acousticness     Float?
  instrumentalness Float?
  createdAt        DateTime   @default(now())

  @@index([albumId])
  @@map("music_tracks")
}

model ArtistRelation {
  id           String      @id @default(uuid())
  fromArtistId String
  toArtistId   String
  fromArtist   MusicArtist @relation("from", fields: [fromArtistId], references: [id])
  toArtist     MusicArtist @relation("to", fields: [toArtistId], references: [id])
  relationType String      // similar_to | collaborated_with | influenced_by | member_of
  strength     Float       @default(0.5)
  source       String      @default("spotify")
  createdAt    DateTime    @default(now())

  @@unique([fromArtistId, toArtistId, relationType])
  @@index([fromArtistId])
  @@index([toArtistId])
  @@map("artist_relations")
}

model MusicGenre {
  id          String   @id @default(uuid())
  name        String   @unique
  nameKo      String   @default("")
  parentGenre String?
  description String   @default("")
  createdAt   DateTime @default(now())

  @@map("music_genres")
}

// ═══════════════════════════════════════════════════════════════════════════
// RAG VECTOR STORAGE
// ═══════════════════════════════════════════════════════════════════════════

model ArticleChunk {
  id             String    @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content        String    @db.Text
  embedding      Unsupported("vector(1536)")
  sourceType     String    // blog | sns | carousel | review
  sourceId       String
  personaId      String?
  topics         String[]  @default([])
  entityMentions String[]  @default([])  // generic name (was artistMentions)
  publishedAt    DateTime?
  chunkIndex     Int       @default(0)
  createdAt      DateTime  @default(now())

  @@index([workspaceId, sourceType])
  @@index([personaId])
  @@map("article_chunks")
}

// ═══════════════════════════════════════════════════════════════════════════
// TOPIC INTELLIGENCE
// ═══════════════════════════════════════════════════════════════════════════

model TrendSnapshot {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  source      String    // google | youtube | naver-datalab | naver-news | naver-blog | reddit | spotify | hackernews
  title       String
  url         String    @default("")
  description String    @default("")
  rank        Int       @default(0)
  fetchedAt   DateTime  @default(now())

  @@index([workspaceId, source, fetchedAt])
  @@index([title])
  @@map("trend_snapshots")
}

model TopicPerformance {
  id              String    @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  topic           String
  category        String    @default("")
  articleCount    Int       @default(0)
  avgEngagement   Float     @default(0)
  lastPublishedAt DateTime?
  coolingUntil    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

