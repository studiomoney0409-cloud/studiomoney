  postType           String           @default("image")
  permalink          String           @default("")
  caption            String           @default("") @db.Text
  thumbnailUrl       String           @default("")
  likeCount          Int              @default(0)
  commentsCount      Int              @default(0)
  timestamp          DateTime
  hashtags           String[]         @default([])
  mentionedUsers     String[]         @default([])
  enrichedContext    String?          @db.Text
  createdAt          DateTime         @default(now())

  @@index([referenceAccountId, timestamp])
  @@index([timestamp])
  @@map("reference_feeds")
}

