// ═══════════════════════════════════════════════════════════════════════════
// PARTNERSHIP SYSTEM
// ═══════════════════════════════════════════════════════════════════════════

model Partner {
  id            String    @id @default(uuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  type          String    // niche-defined; was "artist | label | venue | festival | media | brand"
  contactName   String    @default("")
  contactEmail  String    @default("")
  contactPhone  String    @default("")
  status        String    @default("prospect")
  warmthScore   Int       @default(0)
  musicArtistId String?   // populated only for niche=music
  notes         String    @default("") @db.Text
  lastContactAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  collaborations    Collaboration[]
  outreachCampaigns OutreachCampaign[]

  @@index([workspaceId, status])
  @@index([workspaceId, type])
  @@map("partners")
}

model Collaboration {
  id           String    @id @default(uuid())
  partnerId    String
  partner      Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  title        String
  type         String
  status       String    @default("proposed")
  description  String    @default("") @db.Text
  deliverables Json?
  blogPostIds  String[]  @default([])
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([partnerId])
  @@index([status])
  @@map("collaborations")
}

model OutreachCampaign {
  id             String    @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  partnerId      String?
  partner        Partner?  @relation(fields: [partnerId], references: [id])
  targetName     String
  targetType     String
  targetEmail    String    @default("")
  status         String    @default("draft")
  messageSubject String    @default("")
  messageBody    String    @default("") @db.Text
  sentAt         DateTime?
  repliedAt      DateTime?
  followUpCount  Int       @default(0)
  trendSource    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([workspaceId, status])
  @@map("outreach_campaigns")
}
