  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  weekStart    DateTime  @db.Date
  weekEnd      DateTime  @db.Date
  strategyJson Json
  statusJson   Json?
  agentRunId   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  briefings DailyBriefing[]

  @@index([workspaceId, weekStart])
  @@map("weekly_plans")
}

model DailyBriefing {
  id              String      @id @default(uuid())
  workspaceId     String
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  date            DateTime    @db.Date
  weeklyPlanId    String?
  plan            WeeklyPlan? @relation(fields: [weeklyPlanId], references: [id])
  assignmentsJson Json
  trendSummary    String      @default("") @db.Text
  statusJson      Json?
  agentRunId      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([workspaceId, date])
  @@index([weeklyPlanId])
  @@map("daily_briefings")
}

model ImageGate {
  id             String    @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agentRunId     String
  topic          String
  articleSummary String    @default("") @db.Text
  candidates     Json
  selectedUrls   String[]  @default([])
  status         String    @default("pending")
  platforms      String[]  @default([])
  personaId      String?
  pipelineRunId  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([workspaceId, status])
  @@index([createdAt])
  @@map("image_gates")
}

