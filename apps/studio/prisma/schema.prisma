// ═══════════════════════════════════════════════════════════════════════════
// AI EDITORIAL PIPELINE
// ═══════════════════════════════════════════════════════════════════════════

model PipelineRun {
  id            String    @id @default(uuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  topic         String
  angle         String    @default("")
  contentType   String    @default("blog")
  personaId     String?
  status        String    @default("running")

  outlineJson   Json?
  researchJson  Json?
  draftContent  String?   @db.Text
  editedContent String?   @db.Text

  qualityScore  Json?
  rewriteCount  Int       @default(0)

  publicationId String?
  publishedAt   DateTime?

  metrics1h           Json?
  metrics24h          Json?
  metrics7d           Json?
  metrics30d          Json?
  engagementRate      Float?
  contentQualityRatio Float?
  feedbackStatus      String    @default("pending")
  feedbackProcessedAt DateTime?

  errorMessage String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blogPost   BlogPost?
  topicDraft TopicDraft?

  @@index([workspaceId, status])
  @@index([personaId])
  @@index([contentType])
  @@index([feedbackStatus])
  @@map("pipeline_runs")
}

// ═══════════════════════════════════════════════════════════════════════════
// TOPIC WORKSHOP
// ═══════════════════════════════════════════════════════════════════════════

model TopicDraft {
  id              String    @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  topic           String
  angle           String    @default("")
  reasoning       String    @default("") @db.Text
  contentType     String    @default("blog")
  status          String    @default("saved")

  sourceType      String    @default("manual") // suggestion | topic-intelligence | autopilot | manual | search
  sourceData      Json?

  trendSources    String[]  @default([])
  relatedEntities String[]  @default([])
  formats         Json?

  personaId       String?
  pipelineRunId   String?   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages    TopicMessage[]
  pipelineRun PipelineRun? @relation(fields: [pipelineRunId], references: [id])

  @@index([workspaceId, status])
  @@index([createdAt])
  @@map("topic_drafts")
}

model TopicMessage {
  id           String     @id @default(uuid())
  topicDraftId String
  draft        TopicDraft @relation(fields: [topicDraftId], references: [id], onDelete: Cascade)
  role         String
  content      String     @db.Text
  topicUpdate  Json?
  createdAt    DateTime   @default(now())

  @@index([topicDraftId])
  @@map("topic_messages")
}

model ImageGenHistory {
  id            String    @id @default(uuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prompt        String    @db.Text
  revisedPrompt String?   @db.Text
  provider      String
  imageUrl      String    @db.Text
  width         Int
  height        Int
  aspectRatio   String    @default("square")
  purpose       String    @default("general")
  costUsd       Float     @default(0)
  elapsedMs     Int       @default(0)
  createdAt     DateTime  @default(now())

  @@index([workspaceId, provider])
  @@index([createdAt])
  @@map("image_gen_history")
}

